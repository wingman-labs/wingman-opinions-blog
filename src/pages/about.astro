---
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="About"
	description="Blog de opiniones y estrategia aplicada"
	pubDate={new Date('April 18 2026')}
	heroImage={AboutHeroImage}
>
	<p>
		Este blog comparte opiniones prácticas sobre productividad, estrategia y AI aplicada.
	</p>
	<p>
		El enfoque es convertir ideas en decisiones accionables, sin ruido y con criterio.
	</p>
	<p>
		Política editorial: no publicar datos sensibles ni información que comprometa privacidad.
	</p>
</Layout>
